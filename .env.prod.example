# Copy to .env.prod, fill in real values, then:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Host port the app listens on (default 80 → http://your-host/)
APP_PORT=80

# Database (used by Postgres container and stitched into DATABASE_URL)
POSTGRES_USER=storeapp
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=storeapp

# Public-facing origins
# CLIENT_ORIGIN = browser origin that calls the API (comma-separated allowed)
# PUBLIC_WEB_URL = base URL embedded into the QR codes for storefronts
CLIENT_ORIGIN=https://your-domain.com
PUBLIC_WEB_URL=https://your-domain.com

# Auth
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Razorpay (use LIVE keys for production)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx
